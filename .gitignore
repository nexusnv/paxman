# --- Paxman Python .gitignore ---
# Per sprint-01-foundation.md D1.4.
# Patterns follow the Python gitignore template (https://github.com/github/gitignore)
# plus Paxman-specific exclusions (tests/fixtures/generated/, .sisyphus/, .codegraph/).

# Local dev artifacts
.sisyphus/
.codegraph/
.understand-anything/

# --- Agentic / harness / toolchain artifacts (Sprint 11) ---
# Different developers may use different harnesses, agents, and tooling.
# These are local dev artifacts only and must not be version-controlled.
# The universal project knowledge base lives at ./AGENTS.md and IS tracked.

# OpenCode skills (per-developer toolchain)
.agents/

# Omo harness (ralph-loop, continuation cache, etc.)
.omo/

# Skills lockfile (tool-specific)
skills-lock.json

# Harness-specific agent files (per-developer, not project-wide)
CLAUDE.md
CODEX.md
kilo.md
.gemini/
.cursor/
.aider*
.windsurf/
.continue/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
downloads/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter Notebook
.ipynb_checkpoints

# Pytest
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# mypy
.mypy_cache/

# pyright
.pyright/

# ruff
.ruff_cache/

# hypothesis
.hypothesis/

# uv (lockfile IS committed so CI can run `uv sync --frozen` deterministically)
# uv.lock

# IDEs / editors
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test data (Sprint 5+: programmatic fixtures)
# Note: the directory is now tests/fixtures/factories/ (committed source).
# If/when we add a gitignored cache of generated outputs, it goes here.
tests/fixtures/factories/__pycache__/

# Local coverage / runtime artifacts
coverage.json
.worktress/
.worktrees/
.benchmarks/
site/
